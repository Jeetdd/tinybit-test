{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "node": "20.18.0",
      "cache": {
        "key": "dev-v3"
      },
      "env": {
        "npm_config_legacy_peer_deps": "true",
        "ORG_GRADLE_PROJECT_reactNativeArchitectures": "arm64-v8a,x86_64"
      }
    },
    "preview": {
      "channel": "preview",
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "node": "20.18.0",
      "cache": {
        "key": "preview-v3"
      },
      "env": {
        "npm_config_legacy_peer_deps": "true",
        "EXPO_PUBLIC_API_BASE_URL": "https://tinybit-test-production.up.railway.app/api",
        "EXPO_PUBLIC_OWM_API_KEY": "5469a7d05ccb92456657709cced7668e",
        "ORG_GRADLE_PROJECT_reactNativeArchitectures": "arm64-v8a,x86_64"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "node": "20.18.0",
      "cache": {
        "key": "prod-v3"
      },
      "env": {
        "npm_config_legacy_peer_deps": "true",
        "EXPO_PUBLIC_API_BASE_URL": "https://tinybit-test-production.up.railway.app/api",
        "EXPO_PUBLIC_OWM_API_KEY": "5469a7d05ccb92456657709cced7668e"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
